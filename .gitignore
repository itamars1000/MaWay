# Root-level ignores. Subprojects keep their own .gitignore too
# (runroute-web/.gitignore, route_engine/.gitignore).

# OS / editor noise
.DS_Store
Thumbs.db
*.swp

# Root-level generated artifacts
/cache/
/route.geojson
.pytest_cache/

# Flutter platform skeleton (generated by `flutter create .`)
/.dart_tool/
/build/
/android/
/ios/
/web/
/linux/
/macos/
/windows/
.flutter-plugins
.flutter-plugins-dependencies
.packages

# --- safety nets (also covered by per-directory .gitignore) ---
# Never commit secrets or heavy/regenerable trees.
**/.env
**/.env.*
!**/.env.example
**/node_modules/
**/.venv/
**/__pycache__/
**/*.pyc
**/dist/
route_engine/regions/_cache/
route_engine/feedback.jsonl
route_engine/learned_weights.json
