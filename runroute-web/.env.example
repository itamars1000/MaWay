# Route generation now uses the local Python engine (route_engine) via HTTP.
# Start it from the project root:
#   route_engine/.venv/Scripts/python -m uvicorn route_engine.api:app --port 8000
# Override the URL here if it runs elsewhere (default: http://localhost:8000).
VITE_ENGINE_URL=http://localhost:8000

# (Legacy) OpenRouteService key — only needed if you switch back to the ORS path.
# Get a free key: https://openrouteservice.org/dev/#/signup
VITE_ORS_API_KEY=your_ors_api_key_here

# Supabase — optional Google sign-in + route sync. Public client values (safe in
# the browser; protected by Row Level Security). From Supabase → Project Settings
# → API. Leave unset to keep the app guest-only (no sign-in button shown).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_publishable_or_anon_key
